<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="RFE_OnSite.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7"/>
    </startup>
  
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2"/>
  </System.Windows.Forms.ApplicationConfigurationSection>
  
  <runtime>
  
       <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
  
            <dependentAssembly>
  
                 <assemblyIdentity name="ZedGraph" publicKeyToken="02a83cbd123fcd60" culture="neutral"/>
  
                 <bindingRedirect oldVersion="0.0.0.0-5.1.7.430" newVersion="5.1.7.430"/>
  
            </dependentAssembly>
  
       </assemblyBinding>
  
  </runtime>
  <userSettings>
    <RFE_OnSite.Properties.Settings>
      <setting name="Persist_ClientTextState" serializeAs="String">
        <value>Client</value>
      </setting>
      <setting name="Persist_LocationTextState" serializeAs="String">
        <value>Collection Location</value>
      </setting>
      <setting name="Persist_FloorTextState" serializeAs="String">
        <value>Floor</value>
      </setting>
      <setting name="Persist_FloorNumberState" serializeAs="String">
        <value>1</value>
      </setting>
      <setting name="Persist_MarkerTextState" serializeAs="String">
        <value>M</value>
      </setting>
      <setting name="Persist_MarkerNumberState" serializeAs="String">
        <value>1</value>
      </setting>
      <setting name="Persist_MarkerIncrementState" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="Persist_FloorEnableState" serializeAs="String">
        <value>Enable</value>
      </setting>
      <setting name="Persist_FloorDecrementState" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="Persist_SweepsCountState" serializeAs="String">
        <value>100</value>
      </setting>
      <setting name="Persist_AutoScaleState" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="Persist_AverageState" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="Persist_PeakState" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="Persist_SaveCsvCheckedState" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="Persist_Preset" serializeAs="String">
        <value/>
      </setting>
      <setting name="Persist_2400State" serializeAs="String">
        <value>False</value>
      </setting>
    </RFE_OnSite.Properties.Settings>
  </userSettings>
</configuration>
